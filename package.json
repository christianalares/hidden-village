{
  "name": "hidden-village",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4+sha512.b2dc20e2fc72b3e18848459b37359a32064663e5627a51e4c74b2c29dd8e8e0491483c3abb40789cfd578bf362fb6ba8261b05f0387d76792ed6e23ea3b1b6a0",
  "scripts": {
    "dev": "pnpm dev:infra && pnpm dev:apps",
    "dev:apps": "turbo dev",
    "dev:infra": "docker compose up -d postgres",
    "dev:web": "pnpm --filter @hidden-village/web dev",
    "dev:jobs": "pnpm --filter @hidden-village/jobs trigger:dev",
    "build": "turbo build",
    "start:web": "pnpm --filter @hidden-village/web start",
    "check": "biome check .",
    "format": "biome format --write .",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "db:generate": "pnpm --filter @hidden-village/db db:generate",
    "db:migrate": "pnpm --filter @hidden-village/db db:migrate",
    "db:migrate:prod": "pnpm --filter @hidden-village/db db:migrate:prod",
    "db:seed": "pnpm --filter @hidden-village/auth seed",
    "db:studio": "pnpm --filter @hidden-village/db db:studio",
    "check-types": "turbo typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "dotenv-cli": "^11.0.0",
    "turbo": "latest",
    "typescript": "latest"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ],
    "overrides": {
      "@opentelemetry/api": "1.9.1"
    }
  }
}
