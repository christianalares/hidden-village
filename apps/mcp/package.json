{
  "name": "@hidden-village/mcp",
  "private": true,
  "type": "module",
  "bin": {
    "hidden-village-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --platform node --clean",
    "dev": "dotenv -e ../../.env -- tsx src/index.ts",
    "lint": "biome check .",
    "start": "node dist/index.js",
    "start:local": "dotenv -e ../../.env -- node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "echo 'No MCP tests yet'",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@hidden-village/finance": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsup": "^8.5.1",
    "tsx": "4.22.0",
    "typescript": "6.0.3"
  }
}
